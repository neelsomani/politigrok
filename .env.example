# Required for Grok requests
XAI_API_KEY=

# Optional
XAI_API_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning

# Storage backend: auto | s3 | local
STORAGE_BACKEND=auto

# S3 settings (used when S3_BUCKET is set, or STORAGE_BACKEND=s3)
S3_BUCKET=
S3_PREFIX=politifact
AWS_REGION=

# Local fallback base directory
LOCAL_DATA_DIR=data
